public class pairS {
    public static void main(String[] args) {
        int[] arr = {1,2,3,4,5,6,7,8};
        int l=0;
        int r=arr.length-1;
        int target=8;
        while (l<r) {
            if(arr[l]+arr[r]>target){
                System.out.println(arr[l]+","+arr[r]);
            }
            l++;
            r--;
        }
    }
}
