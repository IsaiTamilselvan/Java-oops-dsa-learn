public class midEle {
    public static void main(String[] args) {
        int[] arr = {1,2,3,4,5,6,7};
        int l=0;
        int r=arr.length-1;

        while (l<=r) {
            if (l!=r) {
                System.err.println(arr[l]+","+arr[r]);
            }
            l++;
            r--;
            if(l==r){
                System.err.println(arr[l]);
            }
        }
    }
}
