public class palin {
    public static void main(String[] args) {
        int[] arr = {1,2,3,4,5,6};
        System.out.println("palindrome: "+ispalin(arr));
    }
    public static boolean ispalin(int[] arr) {
        int l=0;
        int r=arr.length-1;
        while (l<r) {
            if(arr[l]!=arr[r]){
                return false;
            }
            l++;
            r--;
        }
        return true;
    }
}
