
public class pairSum{
    public static void main(String args[]){
        int[] arr = {1,2,3,4,5,6};
        int sum=0;
        int l=0;
        int r=arr.length-1;

        while (l<r) {//i ignore the middle as it was not pair
            sum+=arr[l]+arr[r];
            l++;
            r--;
        }
        System.out.println(sum);
    }
}
