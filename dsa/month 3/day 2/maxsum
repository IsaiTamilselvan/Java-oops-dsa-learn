public class maxsum {

    public static void main(String[] args) {
        int[] arr = {2,6,1,8,3,5};
        int k = 3;
        int sum=0;
        for (int i=0;i<k;i++) {
            sum+=arr[i];
        }
        int maxsum=sum;
        for(int i=k;i<arr.length;i++){
            sum-=arr[i-k];
            sum+=arr[i];
            if(maxsum<sum){
                maxsum=sum;
            }
        }
        System.out.println(maxsum);
    }
}
