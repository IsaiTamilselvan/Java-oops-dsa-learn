public class binins{
    public static void main(String args[]){
        int[] arr={1,3,5,7};
        int target=4;

        int left=0;
        int right=arr.length-1;

        while(left<=right){
            int mid=(left+right)/2;

            if(arr[mid]<target){
                left=mid+1;
            }else{
                right=mid-1;
            }
        }
        System.out.println(left);
    }
}
