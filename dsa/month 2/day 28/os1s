public class os1s{
    public static void main(String args[]){
        int[] arr = {0,1,0,1,1,0,0,1};
        int l=0;

        for(int i=arr.length-1;i>=0;i--){
            while(arr[l]==0){
                l++;
            }
            if(arr[i]==0){
                int temp=arr[l];
                arr[l]=arr[i];
                arr[i]=temp;
                l++;
            }
        }
        for(int i=0;i<arr.length;i++){
            System.out.println(arr[i]);
        }
    }
}
