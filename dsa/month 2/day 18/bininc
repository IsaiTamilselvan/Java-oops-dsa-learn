public class bininc{
    public static void main(String args[]){
        int[] arr={1,3,5,6};
        int target=5;

        int left=0;
        int right=arr.length;

        while(left<right){
            int mid=(left+right)/2;

            if(arr[mid]<target){
                left=mid+1;
            }else{
                right=mid;
            }
        }
        System.out.println(left);
    }
}
