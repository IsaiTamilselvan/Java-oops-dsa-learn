public class sumPair{
    public static void main(String args[]){
        int[] arr = {1,2,3,4,5};
        int target=6;
        int l=0;
        int r=arr.length-1;

        while(l<r){
            if(arr[l]+arr[r]==target){
                System.out.println("{"+arr[l]+","+arr[r]+"}");
                l++;
                r--;
            }else if(arr[l]+arr[r] > target){
                r--;
            }else{
                l++;
            }
        }
    }
}
