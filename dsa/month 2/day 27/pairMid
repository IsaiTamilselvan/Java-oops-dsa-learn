public class pairMid{
    public static void main(String args[]){
        int[] arr = {1,2,3,4,5,6,7,8,9};

        int l=0;
        int r=arr.length-1;

        while(l<r){
            System.out.println(arr[l]+","+arr[r]);
            l++;
            r--;
            if(l==r){
                System.out.println("middle = "+arr[l]);
            }
        }
    }
}
