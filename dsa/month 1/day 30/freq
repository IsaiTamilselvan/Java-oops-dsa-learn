public class freq{
    public static void main(String args[]){
        int[] freq=new int[26];
        String s="zoho";

        for(int i=0;i<s.length();i++){
            int idx = s.charAt(i)-'a';

            if(freq[idx] > 0){
                System.out.println("duplicate");
                return;
            }
            freq[idx]++;
        }
        System.out.println("no duplicate");
    }
}
