public class Oddeven{
    public static void main(String args[]){
        int[] arr={1, 2, 3, 4, 5, 6};
        int odd=0;
        int even=0;

        for(int i=0;i<arr.length;i++){
            if(arr[i]%2==1){
                odd++;
            }else{
                even++;
            }
        }
        System.out.println("Even: "+even);
        System.out.println("Odd: "+odd);
    }
}
