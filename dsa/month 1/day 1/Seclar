public class Seclar{
    public static void main(String args[]){
        int[] arr = {3, 7, 2, 9, 5};
        int lar=arr[0];
        int Seclar=0;

        for(int i=0;i<arr.length;i++){
            if(arr[i]>lar){
                Seclar=lar;
                lar=arr[i];
            }
        }
        System.out.println("Second Largest: "+Seclar);
    }
}
