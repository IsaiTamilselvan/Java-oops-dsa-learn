public class Greatest{
    public static void main(String args[]){
        int[] arr = {3, 7, 2, 9, 5};
        int greatest = 0;

        for(int i=0;i<arr.length;i++){
            if(arr[i]>greatest){
                greatest=arr[i];
            }
        }
        System.out.println("Greatest: "+greatest);
    }
}
