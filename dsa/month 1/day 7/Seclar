public class Seclar{
    public static void main(String args[]){
        int[] arr={8, 3, 5, 1, 9};
        int fst=Integer.MIN_VALUE;
        int sec=Integer.MIN_VALUE;

        for(int i=0;i<arr.length;i++){
            if(arr[i]>fst){
                sec=fst;
                fst=arr[i];
            }
            else if(arr[i] > sec && arr[i] != fst){
                sec = arr[i];
            }
        }
        System.out.println("Second Largest: "+sec);
    }
}
