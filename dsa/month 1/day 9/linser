public class linser{
    public static void main(String args[]){
        int[] arr={5, 3, 7, 3, 9};
        int target=3;

        for(int i=0;i<arr.length;i++){
            if(arr[i]==target){
                System.out.println("Element found at: "+i);
                return;
            }
        }
    }
}
