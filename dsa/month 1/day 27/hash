import java.util.*;
public class hash{
    public static void main(String args[]){
        HashMap<Integer, Integer> map = new HashMap<>();
        int[] arr={3,3,2,1,2};

        for(int num:arr){
            if(map.containsKey(num)){
                map.put(num,map.get(num)+1);
            }else{
                map.put(num,1);
            }
        }
        
            System.out.println(map);
    }
}
