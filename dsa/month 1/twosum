//but now solver it under 2 mins
public class twosum{
    public static void main(String args[]){
        int[] arr={2,0,4,3,5};
        int target=5;

        for(int i=0;i<arr.length-1;i++){

            for(int j=i+1;j<arr.length;j++){
                if(arr[j]==(target-arr[i])){
                    System.out.println(i+","+j);
                    return;
                }
            }
        }
    }
}
