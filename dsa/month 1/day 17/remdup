public class remdup{
    public static void main(String args[]){
        int[] arr={1, 1, 2, 2, 3, 3};

        for(int i=0;i<arr.length;i++){
            boolean vist=false;
            for(int k=0;k<i;k++){
                if(arr[k]==arr[i]){
                    vist=true;
                }
            }
            if(vist){
                continue;
            }
            System.out.print(arr[i]);
        }
    }
}
