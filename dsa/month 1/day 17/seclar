public class seclar{
    public static void main(String args[]){
        int[] arr={10, 20, 5, 8};
        int lar=Integer.MIN_VALUE;
        int seclar=Integer.MIN_VALUE;

        for(int i=0;i<arr.length;i++){
            if(lar<arr[i]){
                seclar=lar;
                lar=arr[i];
            }
        }
        System.out.println("Second largest: "+seclar);
    }
}
