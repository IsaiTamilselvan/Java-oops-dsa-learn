public class presum{
    public static void main(String args[]){
        int[] arr={2, 1, 3, 2};
        int pr=arr[0];
        for(int i=1;i<arr.length;i++){
            pr+=arr[i];
        }
        arr[arr.length-1]=pr;

        for(int i=0;i<arr.length;i++){
            System.out.print(arr[i]);
        }
    }
}
