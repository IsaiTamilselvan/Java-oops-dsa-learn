public class sortrota{
    public static void main(String args[]){
        int[] arr= {1, 4, 3, 2, 5};
        int brk=0;

        for(int i=1;i<arr.length;i++){
            if(arr[i-1]>arr[i]){
                brk++;
            }
        }
        if(brk<=1){
            System.out.println("true");
        }else{
            System.out.println("false");
        }
    }
}
