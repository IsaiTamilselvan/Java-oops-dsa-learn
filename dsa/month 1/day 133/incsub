public class incsub {
    public static void main(String args[]){
        int[] arr = {1, 3, 5, 4, 7};

        int count = 1;
        int max = 1;

        for(int i = 1; i < arr.length; i++){
            if(arr[i] > arr[i-1]){
                count++;
                if(count > max){
                    max = count;
                }
            } else {
                count = 1;
            }
        }

        System.out.println("Longest: " + max);
    }
}
