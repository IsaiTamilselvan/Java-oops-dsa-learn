public class lefneg{
    public static void main(String args[]){
        int[] arr={1, -2, 3, -4, 5};
        int pos=0;

        for(int i=0;i<arr.length;i++){
            if(arr[i]<0){
                int temp=arr[pos];
                arr[pos]=arr[i];
                arr[i]=temp;
                pos++;
            }
        }
        for(int i=0;i<arr.length;i++){
            System.out.print(arr[i]+",");
        }
    }
}
