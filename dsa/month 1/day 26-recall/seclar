public class seclar{
    public static void main(String args[]){
        int[] arr={4, 2, 78, 45, 4, 3};
        int lar=Integer.MIN_VALUE;
        int seclar=Integer.MIN_VALUE;

        for(int i=0;i<arr.length;i++){
            if(arr[i]>lar){
                seclar=lar;
                lar=arr[i];
                continue;
            }
            else if(arr[i]>seclar && arr[i]!=lar){
                seclar=arr[i];
            }
        }
        System.out.println(seclar);
    }
}
