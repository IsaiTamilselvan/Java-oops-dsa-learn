public class profit{
    public static void main(String args[]){
        int[] arr={1, 2 ,4, 5, 6, 3, 1};
        int min=arr[0];
        int max=0;
        int profit=0;

        for(int i=0;i<arr.length;i++){
            if(arr[i]<min){
                min=arr[i];
            }

            profit=arr[i]-min;

            if(max<profit){
                max=profit;
            }
        }
        System.out.println("MAX profit: "+max);
    }
}
