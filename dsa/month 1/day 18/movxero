public class movzero{
    public static void main(String args[]){
        int[] arr={0, 1, 0, 3, 12, 0};
        int pos=0;

        for(int i=0;i<arr.length;i++){
            if(arr[i]!=0){
                int temp=arr[pos];
                arr[pos]=arr[i];
                arr[i]=temp;
                pos++;
            }
        }
        for(int i=0;i<arr.length;i++){
            System.out.print(arr[i]+",");
        }
    }
}
