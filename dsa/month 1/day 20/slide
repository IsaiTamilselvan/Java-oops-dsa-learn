public class slide{
    public static void main(String args[]){
        int[] arr={1,4,2,10,2};
        int k=2;
        int sum=0;
        int maxsum=0;

        for(int i=0;i<k;i++){
            sum+=arr[i];
        }
        maxsum=sum;

        for(int i=k;i<arr.length;i++){
            sum=sum-arr[i-k]+arr[i];

            if(sum>maxsum){
                maxsum=sum;
            }
        }
        System.out.println(maxsum);
    }
}
