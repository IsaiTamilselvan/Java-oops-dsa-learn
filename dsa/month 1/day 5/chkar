public class Chkar{
    public static void main(String args[]){
        int[] a={1, 2, 3, 4};
        int[] b={1, 2, 2, 3};

        System.out.println("Equal: "+chk(a,b));
    }
    public static boolean chk(int[] a,int[] b){
        for(int i=0;i<a.length;i++){
            if(a[i]!=b[i]){
                return false;
            }
        }
        return true;
    }
}
