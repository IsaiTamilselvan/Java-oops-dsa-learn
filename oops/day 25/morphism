//ppolymorphism revision 
class addall{

    static int addall(int a,int b){
        return a+b;
    }

    static int addall(int a, int b,int c){
        return a+b+c;
    }

    static int addall(){
        System.out.println("give some value to perform addition");
        return 0;
    }

}

public class morphism{
    public static void main(String args[]){
        
        System.out.println(addall.addall());
        System.out.println(addall.addall(2,3));
        System.out.println(addall.addall(2,3,5));
    }
}
