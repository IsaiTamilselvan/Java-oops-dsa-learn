class rectangle{
    int length;
    int width;

    rectangle(int length,int width){
        this.length=length;
        this.width=width;
    }

    public int area(){
        return length*width;
    }

    public int perimeter(){
        return 2*(length*width);
    }
}
public class rect{
    public static void main(String args[]){
        rectangle obj = new rectangle(6,3);

        System.out.println(obj.area());
    }
}
